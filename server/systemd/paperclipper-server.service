[Unit]
Description=Paper Clipper AI proxy (FastAPI / uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/home/user/gitrepos/20260602-paper-clipper/server
ExecStart=/home/user/gitrepos/20260602-paper-clipper/server/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
