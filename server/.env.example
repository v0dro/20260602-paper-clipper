# Copy to .env and fill in. .env is gitignored.

# Your Gemini Developer API key (from Google AI Studio). Stays server-side only.
GEMINI_API_KEY=

# A long random shared secret. The app sends it as "Authorization: Bearer <PROXY_TOKEN>".
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PROXY_TOKEN=

# Optional overrides.
GEMINI_MODEL=gemini-2.5-flash
PORT=8000

# Token prices (USD per 1M tokens) used to estimate per-request cost in the request_log.
# Defaults are gemini-2.5-flash list prices; update these whenever GEMINI_MODEL changes.
GEMINI_PRICE_INPUT_PER_M=0.30
GEMINI_PRICE_OUTPUT_PER_M=2.50

# Feedback: each submission is saved as an .eml file in FEEDBACK_DIR (relative to the server dir
# unless absolute). No email is actually sent; FEEDBACK_TO is just the "To:" header recorded.
FEEDBACK_DIR=feedback
FEEDBACK_TO=developer@example.com

# Max successful analyses per user per day (per X-User-Id header). Counts persist in USAGE_DB.
DAILY_LIMIT=100
USAGE_DB=usage.db
